# Application Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME="Intelligent Document Knowledge System"
APP_VERSION="1.0.0"
DEBUG=false

# Paths
DATA_DIR=./data
VECTORSTORE_DIR=./data/vectorstore
LOGS_DIR=./logs

# Database
DATABASE_URL=sqlite:///./data/clarion.db

# Embedding Model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100

# LLM Provider Selection
# Options: "ollama", "openai", "deepseek", "gemini"
LLM_PROVIDER=ollama

# DeepSeek API (set LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Google Gemini API (set LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI API (set LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Ollama Configuration (Local Models) - set LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3:latest
OLLAMA_API_BASE=http://localhost:11434/v1

# LLM Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Available models (installed Ollama):
# - qwen3:latest (Qwen 3 8B)
# - deepseek-coder:6.7b (DeepSeek Coder 6.7B)
# - gemma3:4b (Gemma 3 4B)

# Retrieval
DEFAULT_TOP_K=5
SIMILARITY_THRESHOLD=0.5

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=[".pdf", ".docx"]
